# Set the API key for your chosen provider(s).
# LiteLLM routes to the right provider based on model prefix.
# See https://docs.litellm.ai/docs/providers for supported providers.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Default model used when no specific model/complexity is set
FREUDIAN_DEFAULT_MODEL=claude-sonnet-4-5-20250514

# Per-layer model overrides (optional — defaults are sensible)
FREUDIAN_CONSCIOUS_MODEL=claude-haiku-4-5-20241022
FREUDIAN_PRECONSCIOUS_MODEL=claude-sonnet-4-5-20250514
FREUDIAN_UNCONSCIOUS_MODEL=claude-opus-4-5-20250514
FREUDIAN_AGENT_MODEL=claude-sonnet-4-5-20250514
FREUDIAN_DB_PATH=anima.db
TELEGRAM_BOT_TOKEN=your-bot-token-here
